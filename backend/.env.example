# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/habesha-store

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_this
JWT_EXPIRE=7d

# Frontend
FRONTEND_URL=http://localhost:3000

# Stripe Payment
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Telebirr Payment (Ethiopian)
TELEBIRR_API_KEY=your_telebirr_api_key
TELEBIRR_MERCHANT_ID=your_telebirr_merchant_id
TELEBIRR_API_URL=https://api.telebirr.com

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Bank Transfer
BANK_NAME=Commercial Bank of Ethiopia
BANK_ACCOUNT=1234567890
BANK_ROUTING=123456

# Email Service
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Admin
ADMIN_EMAIL=admin@habeshastore.com
ADMIN_PASSWORD=admin_password_change_this